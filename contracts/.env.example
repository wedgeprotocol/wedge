# Wedge — local environment template
# Copy this file to `.env` (which is gitignored) and fill in real values.

# Base mainnet RPC. Used by:
#   - integration tests via `make fork`
#   - the scheduled mainnet-fork CI job (set as repo secret BASE_RPC_URL)
# Recommended providers: Alchemy, QuickNode. Free tiers are fine for development.
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/REPLACE_ME

# Etherscan v2 multichain API key for contract verification after deploy.
# Same key works for every supported chain including Base (chain id 8453).
# Required only when running `forge verify-contract` or the deploy scripts.
ETHERSCAN_API_KEY=REPLACE_ME
